{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "moduleResolution": "bundler", 
    "module": "ESNext",
    "importHelpers": true,
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "types": ["node"], // <-- AJOUTEZ "vitest/globals" ICI
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}